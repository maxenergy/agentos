{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://agentos.local/schemas/AUTODEV_SPEC.schema.json",
  "title": "AgentOS AutoDev Spec",
  "type": "object",
  "additionalProperties": true,
  "required": [
    "schema_version",
    "generated_by",
    "generated_by_skill_pack",
    "agentos_min_version",
    "created_at",
    "objective",
    "mode",
    "source_of_truth",
    "tasks"
  ],
  "properties": {
    "schema_version": {
      "const": "1.0.0"
    },
    "generated_by": {
      "type": "string"
    },
    "generated_by_skill_pack": {
      "type": "string"
    },
    "agentos_min_version": {
      "type": "string"
    },
    "created_at": {
      "type": "string"
    },
    "objective": {
      "type": "string"
    },
    "mode": {
      "type": "string"
    },
    "source_of_truth": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "tasks": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": true,
        "required": [
          "title"
        ],
        "properties": {
          "task_id": {
            "type": "string"
          },
          "title": {
            "type": "string"
          },
          "allowed_files": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "blocked_files": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "verify_command": {
            "type": "string"
          },
          "acceptance": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "acceptance_criteria": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "max_retries": {
            "type": "integer",
            "minimum": 0
          }
        },
        "anyOf": [
          {
            "required": [
              "acceptance"
            ]
          },
          {
            "required": [
              "acceptance_criteria"
            ]
          }
        ]
      }
    }
  }
}
